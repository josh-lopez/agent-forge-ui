{
  "name": "agent-forge-ui",
  "version": "0.1.0",
  "description": "Live demonstration web UI for agent-forge",
  "private": true,
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "build": "node_modules/.bin/vite build",
    "build:analyze": "node_modules/.bin/vite build && node scripts/assert-no-simulator.mjs",
    "dev": "node_modules/.bin/vite",
    "preview": "node_modules/.bin/vite preview",
    "typecheck": "node_modules/.bin/tsc --noEmit",
    "lint:html": "node_modules/.bin/htmlhint --config .htmlhintrc index.html",
    "test": "node_modules/.bin/vitest run && bash tests/run_all.sh",
    "test:unit": "node_modules/.bin/vitest run",
    "test:watch": "node_modules/.bin/vitest"
  },
  "devDependencies": {
    "htmlhint": "^1.1.4",
    "jsdom": "^24.1.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.1"
  }
}
