{
  "name": "agent-forge-ui",
  "version": "0.1.0",
  "description": "Live demonstration web UI for agent-forge",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint:html": "htmlhint --config .htmlhintrc index.html",
    "test:unit": "vitest run",
    "test:scripts": "bash tests/run_all.sh",
    "test": "vitest run && bash tests/run_all.sh"
  },
  "devDependencies": {
    "htmlhint": "^1.1.4",
    "jsdom": "^24.1.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
